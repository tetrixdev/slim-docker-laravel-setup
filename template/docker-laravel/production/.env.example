APP_NAME={{PROJECT_NAME}}
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL={{PRODUCTION_URL}}

DB_CONNECTION=pgsql
DB_HOST={{PROJECT_NAME}}-postgres
DB_PORT=5432
DB_DATABASE={{PROJECT_NAME}}
DB_USERNAME={{PROJECT_NAME}}
# Database password (REQUIRED)
# This MUST be set before deployment - generate with: openssl rand -base64 32
# Docker Compose will fail if this is not set or is empty
DB_PASSWORD=

NGINX_PORT=80